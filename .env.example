# AskOC local demo defaults. Copy to .env for local overrides; keep real secrets out of git.

ASKOC_HTTP_ADDR=:9080
ASKOC_AUTH_ENABLED=false
ASKOC_AUTH_TOKEN=
ASKOC_LOG_LEVEL=info

ASKOC_BANNER_URL=http://localhost:9081
ASKOC_PAYMENT_URL=http://localhost:9082
ASKOC_CRM_URL=http://localhost:9083
ASKOC_RAG_CHUNKS_PATH=data/rag-chunks.json

# Empty workflow URL uses the in-process deterministic client.
ASKOC_WORKFLOW_URL=
ASKOC_WORKFLOW_TIMEOUT_SECONDS=5
ASKOC_WORKFLOW_SIGNATURE=
ASKOC_WORKFLOW_SIGNATURE_HEADER=X-AskOC-Workflow-Signature
ASKOC_WORKFLOW_MAX_RETRIES=1

# Stub mode is the default and does not require a live model or API key.
ASKOC_PROVIDER=stub
ASKOC_PROVIDER_MODEL=demo-placeholder
ASKOC_PROVIDER_ENDPOINT=
ASKOC_PROVIDER_API_KEY=
ASKOC_PROVIDER_TIMEOUT_SECONDS=5

# Optional host ports for Docker Compose. Change these to another 9xxx range if needed.
ASKOC_API_PORT=9080
ASKOC_BANNER_PORT=9081
ASKOC_PAYMENT_PORT=9082
ASKOC_CRM_PORT=9083
ASKOC_WORKFLOW_PORT=9084
ASKOC_LMS_PORT=9085
